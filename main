import requests
import unicodedata  #used to anglicize French characters in city names, e.g. "Québec" to "Quebec"
from datetime import datetime

"""Fetches weather data from the API and returns it as a JSON object. Handles connection errors and prints appropriate messages based on the response status code."""
def getData():  
    URL_OPTIONS = '?limit=1000&f=json&lang=en-CA'
    CITY_WEATHER_URL = 'collections/citypageweather-realtime/items'
    url = f"https://api.weather.gc.ca/{CITY_WEATHER_URL}{URL_OPTIONS}"
    response = requests.get(url)
    
    if response.status_code == 200:
        data = response.json()
        print('Connected to API')
        return data
    
    elif response.status_code == 404:
        print('Cannot reach URL or content not found')
    else:
        print(f"Error has occurred. Code: {response.status_code}")

"""Santizes city names in the data and builds a list of city names from the API call"""
def buildCityList(data):    
    cities = []
    for i in data['features']:
         city_name = i['properties']['name']['en']
         city_name = city_name.split('(')[0].strip()    #removes any text in parentheses, e.g. "City of Calgary (Alberta)" becomes "City of Calgary"
         if has_french_chars(city_name):
            city_name = anglicize_city_name(city_name)
         i['properties']['name']['en'] = city_name      #update the city name in the data to the anglicized version if it contained French characters
         cities.append(city_name)
    return cities

"""Converts a city name with French characters to an anglicized version by removing accents and special characters."""
def anglicize_city_name(name):
    return unicodedata.normalize('NFKD', name).encode('ascii', 'ignore').decode('ascii')
    
"""Checks if the string contains any specific French characters."""
def has_french_chars(text):
    FRENCH_CHARS = "àáâãäåæçèéêëìíîïðñòóôõöøùúûüýþÿÀÂÉÈÊËÎÏÔŒÙÛÜÇ"
    return any(char in FRENCH_CHARS for char in text)

"""Prompts the user to enter a city name and checks if it exists in the API data. If found, returns the city's weather data; otherwise, prompts again."""
def getCity(data):
    features = data['features']
    found = False

    while found == False:
        city_name = input("Please enter your city: ").title()
        for i in features:  #loop through data to find English city name
            if i['properties']['name']['en'] == city_name:
                found = True
                print('Found city')
                city = i['properties']
                return city
        print('City was not found')

"""Extracts and prints the current weather conditions for the specified citys. Handles missing data gracefully by using chained get() calls with default values."""
def getCurrentConditions(city):
        city_name = city['region']['en'] #How the city describes itself, e.g. "City of Calgary"
        city_conditions = city['currentConditions']
        
        #Chaining dictionary get() calls to protect from missing fields in the data
        temperature = city_conditions.get('temperature', {}).get('value', {}).get('en', 'No temperature data')                      #city_conditions['temperature']['value']['en']
        cloud_conditions = city_conditions.get('condition', {}).get('en', 'No cloud cover data')                                    #city_conditions['condition']['en']
        humidity = city_conditions.get('relativeHumidity', {}).get('value', {}).get('en', 'No humidity data')                       #city_conditions['relativeHumidity']['value]['en']
        wind_speed = city_conditions.get('wind', {}).get('speed', {}).get('value', {}).get('en', 'No wind speed data')              #city_conditions['wind]['speed']['value']['en']
        wind_direction = city_conditions.get('wind', {}).get('direction', {}).get('value', {}).get('en', 'No wind direction data')  #city_conditions['wind']['direction']['value']['en']
        wind_gusts = city_conditions.get('wind', {}).get('gust', {}).get('value', {}).get('en', 'No wind gust data')                #city_conditions['wind']['gust']['value']['en']
        air_pressure = city_conditions.get('pressure', {}).get('value', {}).get('en', 'No air pressure data')                       #city_conditions['pressure']['value']['en']
        dew_point = city_conditions.get('dewpoint', {}).get('value', {}).get('en', 'No dew point data')                             #city_conditions['dewpoint']['value']['en']

        print('==============================')
        print(f'Current conditions for {city_name}: ')
        print(f'Current temperature: {temperature}C')
        print(f'Conditions: {cloud_conditions}')
        print(f'Relative Humidity: {humidity}%')
        print(f'Wind: Up to {wind_speed}km/h blowing from the {wind_direction}, gusting up to {wind_gusts}km/h')
        print(f'Air Pressure: {air_pressure}kPa')
        print(f'Dew Point: {dew_point}C')

def get24hourForecast(city):
    hourlyForecast = city['hourlyForecastGroup']['hourlyForecasts']
    for i in hourlyForecast:
        timestamp = i['timestamp'].replace("Z", "+00:00")
        hour_of_day = datetime.fromisoformat(timestamp).hour
        condition = i.get('condition', {}).get('en', 'No condition data')
        # windchill = i.get('windChill', {}).get('value', {}).get('en', 'N/A')
        temperature = i.get('temperature', {}).get('value', {}).get('en', 'No temperature data')
        wind_speed = i.get('wind', {}).get('speed', {}).get('value', {}).get('en', 'No wind speed data')
        wind_direction = i.get('wind', {}).get('direction', {}).get('value', {}).get('en', 'No wind direction data')
        
        print('==============================')
        print(f'24 hour forecast for {city["region"]["en"]}: ')
        print('-----------------------------')
        print(f'Hour: {hour_of_day}:00')
        print(f'Cloud Conditions: {condition}')
        # print(f'Wind Chill: {windchill}C')    #unsure how to handle a N/A windchill value and units
        print(f'Temperature: {temperature}C')
        print(f'Wind: Up to {wind_speed}km/h blowing from the {wind_direction}')
        
    

def get5dayForecast():
    None


def main():
    CITY_LIST = None    #To be used to build a dropdown menu of cities in the GUI
    current_city = None
    data = None

    data = getData()
    CITY_LIST = buildCityList(data)
    current_city = getCity(data)
    getCurrentConditions(current_city)
    get24hourForecast(current_city)


if __name__ == "__main__":    
    main()

